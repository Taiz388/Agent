# Default domestic LLM provider/model for this project.
# Get SiliconFlow API key from https://cloud.siliconflow.cn
LLM_PROVIDER=siliconflow
LLM_MODEL=THUDM/GLM-Z1-9B-0414
SILICONFLOW_API_KEY=sk_your_siliconflow_key_here

# Optional Hugging Face fallback.
HF_TOKEN=hf_your_token_here

# Optional fallback providers. Leave empty if unused.
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
